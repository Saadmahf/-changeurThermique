<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-deep: #04061a;
    --bg-mid: #080d2e;
    --bg-card: #0d1440;
    --bg-card2: #0a1035;
    --accent-pink: #e040fb;
    --accent-cyan: #00e5ff;
    --accent-violet: #7c4dff;
    --accent-green: #00e676;
    --text-primary: #f0f4ff;
    --text-muted: #8892c0;
    --border: rgba(124, 77, 255, 0.25);
    --glow-pink: 0 0 30px rgba(224,64,251,0.35);
    --glow-cyan: 0 0 30px rgba(0,229,255,0.25);
