    --font-body: 'Space Grotesk', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg-deep); color: var(--text-primary); font-family: var(--font-body); overflow-x: hidden; line-height: 1.65; }
  body::before { content: ''; position: fixed; inset: 0; background: radial-gradient(ellipse 80% 50% at 10% 10%, rgba(124,77,255,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 90% 80%, rgba(0,229,255,0.08) 0%, transparent 60%), radial-gradient(ellipse 50% 60% at 50% 50%, rgba(224,64,251,0.05) 0%, transparent 70%); pointer-events: none; z-index: 0; }
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 5vw; background: rgba(4, 6, 26, 0.85); backdrop-filter: blur(18px); border-bottom: 1px solid var(--border); }
  .nav-logo { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--text-primary); text-decoration: none; cursor: pointer; }
  .nav-logo .logo-icon { width: 32px; height: 32px; background: linear-gradient(135deg, var(--accent-pink), var(--accent-violet)); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; color: #fff; }
  .nav-links { display: flex; gap: 1.5rem; list-style: none; }
  .nav-links a { color: var(--text-muted); text-decoration: none; font-size: 0.88rem; font-weight: 500; transition: color 0.2s; cursor: pointer; }
  .nav-links a:hover { color: var(--accent-cyan); }
  .hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 8rem 5vw 5rem; z-index: 1; overflow: hidden; }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; max-width: 1200px; margin: 0 auto; width: 100%; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(224,64,251,0.12); border: 1px solid rgba(224,64,251,0.3); border-radius: 100px; padding: 0.35rem 1rem; font-size: 0.78rem; font-weight: 600; color: var(--accent-pink); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.5rem; }
  .hero-badge::before { content: ''; width: 6px; height: 6px; background: var(--accent-pink); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
  .hero h1 { font-family: var(--font-display); font-size: clamp(2.2rem, 4.5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin-bottom: 1.2rem; }
  .hero h1 .highlight { background: linear-gradient(90deg, var(--accent-pink), var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-desc { color: var(--text-muted); font-size: 1.05rem; max-width: 480px; margin-bottom: 2rem; line-height: 1.75; }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: linear-gradient(135deg, var(--accent-pink), var(--accent-violet)); color: #fff; border: none; padding: 0.75rem 1.8rem; border-radius: 8px; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; transition: transform 0.2s, box-shadow 0.2s; box-shadow: var(--glow-pink); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(224,64,251,0.5); }
  .btn-outline { background: transparent; color: var(--text-primary); border: 1px solid var(--border); padding: 0.75rem 1.8rem; border-radius: 8px; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; transition: border-color 0.2s, color 0.2s; }
  .btn-outline:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); }
  .hero-visual { display: flex; justify-content: center; align-items: center; }
  .cube-wrapper { position: relative; width: 320px; height: 320px; }
  .cube-bg { position: absolute; inset: -30px; background: radial-gradient(circle, rgba(124,77,255,0.25) 0%, transparent 70%); filter: blur(20px); animation: breathe 4s ease-in-out infinite; }
  @keyframes breathe { 0%, 100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.1); } }
  .cube-svg { position: relative; z-index: 2; width: 100%; height: 100%; animation: float 6s ease-in-out infinite; }
  @keyframes float { 0%, 100% { transform: translateY(0px) rotate(0deg); } 50% { transform: translateY(-15px) rotate(3deg); } }
  section { position: relative; z-index: 1; padding: 5rem 5vw; }
  .section-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
  .section-label { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent-cyan); margin-bottom: 0.75rem; }
  .section-label::before { content: ''; width: 24px; height: 2px; background: var(--accent-cyan); }
  .section-title { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 800; line-height: 1.15; margin-bottom: 1rem; }
  .section-subtitle { color: var(--text-muted); font-size: 1rem; max-width: 600px; margin-bottom: 3rem; line-height: 1.7; }
  .divider { height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent); margin: 0 5vw; }
  .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
  .card:hover { border-color: rgba(224,64,251,0.4); transform: translateY(-3px); }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--accent-pink), var(--accent-violet)); opacity: 0; transition: opacity 0.3s; }
  .card:hover::before { opacity: 1; }
  .card-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 1rem; }
  .card-icon.pink { background: rgba(224,64,251,0.12); }
  .card-icon.cyan { background: rgba(0,229,255,0.12); }
  .card-icon.violet { background: rgba(124,77,255,0.12); }
  .card-icon.green { background: rgba(0,230,118,0.12); }
  .card h3 { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--text-primary); }
  .card p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.65; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .system-section { background: var(--bg-mid); }
  .math-block { background: rgba(124, 77, 255, 0.07); border: 1px solid rgba(124, 77, 255, 0.2); border-left: 3px solid var(--accent-violet); border-radius: 0 12px 12px 0; padding: 1.2rem 1.5rem; font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent-cyan); margin: 1rem 0; overflow-x: auto; line-height: 1.8; white-space: pre; }
  .eq-box { background: var(--bg-card2); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 1.2rem 0; overflow-x: auto; }
  .eq-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-pink); font-weight: 600; margin-bottom: 0.6rem; }
  .eq-content { font-family: var(--font-mono); font-size: 0.88rem; color: var(--text-primary); line-height: 2; }
  .eq-content .var { color: var(--accent-cyan); }
  .eq-content .op { color: var(--accent-pink); }
  .eq-content .num { color: var(--accent-green); }
  .matrix-container { display: inline-block; font-family: var(--font-mono); font-size: 0.82rem; color: var(--accent-cyan); background: rgba(0,229,255,0.04); border: 1px solid rgba(0,229,255,0.15); border-radius: 10px; padding: 1rem 1.5rem; margin: 0.5rem 0; overflow-x: auto; max-width: 100%; }
  .matrix-label { font-family: var(--font-body); font-size: 0.8rem; font-weight: 600; color: var(--accent-pink); margin-bottom: 0.5rem; }
  .plot-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
  .plot-card:hover { border-color: rgba(0,229,255,0.35); transform: translateY(-2px); }
  .plot-header { padding: 1rem 1.5rem; background: rgba(255,255,255,0.03); border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .plot-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot-pink { background: var(--accent-pink); }
  .dot-cyan { background: var(--accent-cyan); }
  .dot-green { background: var(--accent-green); }
  .plot-title { font-size: 0.88rem; font-weight: 600; color: var(--text-primary); flex: 1; }
  .plot-img { width: 100%; display: block; background: #06081e; }
  .steps-list { display: flex; flex-direction: column; gap: 0; position: relative; padding-left: 2rem; }
  .steps-list::before { content: ''; position: absolute; left: 0.7rem; top: 1rem; bottom: 1rem; width: 2px; background: linear-gradient(180deg, var(--accent-pink), var(--accent-cyan)); border-radius: 1px; }
  .step-item { position: relative; padding: 1.2rem 0 1.2rem 2rem; }
  .step-num { position: absolute; left: -2rem; top: 1.3rem; width: 28px; height: 28px; background: linear-gradient(135deg, var(--accent-pink), var(--accent-violet)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 700; color: #fff; z-index: 2; }
  .step-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.3rem; }
  .step-desc { color: var(--text-muted); font-size: 0.88rem; line-height: 1.6; }
  .tag { display: inline-flex; padding: 0.25rem 0.7rem; border-radius: 100px; font-size: 0.75rem; font-weight: 600; margin: 0.2rem; }
  .tag-pink { background: rgba(224,64,251,0.12); color: var(--accent-pink); border: 1px solid rgba(224,64,251,0.25); }
  .tag-cyan { background: rgba(0,229,255,0.1); color: var(--accent-cyan); border: 1px solid rgba(0,229,255,0.2); }
  .tag-violet { background: rgba(124,77,255,0.12); color: #a57fff; border: 1px solid rgba(124,77,255,0.25); }
  .tag-green { background: rgba(0,230,118,0.1); color: var(--accent-green); border: 1px solid rgba(0,230,118,0.2); }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 4rem; }
  .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; text-align: center; }
  .stat-value { font-family: var(--font-display); font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, var(--accent-pink), var(--accent-cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1.2; margin-bottom: 0.25rem; }
  .stat-label { color: var(--text-muted); font-size: 0.82rem; font-weight: 500; }
  .footer-section { background: var(--bg-mid); border-top: 1px solid var(--border); padding: 4rem 5vw 3rem; }
  .footer-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; }
  .footer-brand h3 { font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; margin-bottom: 0.75rem; }
  .footer-brand p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.7; max-width: 350px; }
  .footer-col h4 { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-primary); margin-bottom: 1rem; }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.5rem; }
  .footer-col a { color: var(--text-muted); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; cursor: pointer; }
  .footer-col a:hover { color: var(--accent-cyan); }
  .footer-bottom { max-width: 1200px; margin: 2.5rem auto 0; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; color: var(--text-muted); font-size: 0.82rem; }
  .strip { background: linear-gradient(135deg, rgba(124,77,255,0.12) 0%, rgba(0,229,255,0.08) 50%, rgba(224,64,251,0.1) 100%); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .data-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; margin: 1.5rem 0; }
  .data-table th { background: rgba(124,77,255,0.12); color: var(--accent-cyan); font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; padding: 0.8rem 1rem; text-align: left; border-bottom: 1px solid var(--border); }
  .data-table td { padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--text-muted); font-family: var(--font-mono); font-size: 0.83rem; }
  .data-table td:first-child { color: var(--text-primary); font-weight: 500; font-family: var(--font-body); }
  .data-table tr:hover td { background: rgba(255,255,255,0.02); }
  .data-table .val-cyan { color: var(--accent-cyan); }
  .data-table .val-pink { color: var(--accent-pink); }
  .data-table .val-green { color: var(--accent-green); }
  .result-banner { border-radius: 12px; padding: 1rem 1.5rem; display: flex; align-items: center; gap: 1rem; margin: 1rem 0; font-size: 0.9rem; font-weight: 500; }
  .result-ok { background: rgba(0,230,118,0.08); border: 1px solid rgba(0,230,118,0.2); color: var(--accent-green); }
  .result-warn { background: rgba(255,193,7,0.08); border: 1px solid rgba(255,193,7,0.2); color: #ffc107; }
  .result-icon { font-size: 1.2rem; }
  .content-split { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
  .fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .fade-in.visible { opacity: 1; transform: translateY(0); }
  code { font-family: var(--font-mono); font-size: 0.85em; background: rgba(124,77,255,0.12); color: var(--accent-cyan); padding: 0.1em 0.4em; border-radius: 4px; }
  @media (max-width: 900px) {
    .hero-grid, .content-split, .grid-2, .grid-3, .grid-4, .footer-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
  @media (max-width: 600px) {
    .stats-row { grid-template-columns: 1fr; }
    nav .nav-links { display: none; }
  }
</style>
</head>
